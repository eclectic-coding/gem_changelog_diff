module GemChangelogDiff
  VERSION: String

  self.@configuration: Configuration

  def self.configuration: () -> Configuration
  def self.configure: () { (Configuration) -> void } -> void
  def self.reset_configuration!: () -> Configuration

  class Error < StandardError
  end

  class RepoNotFoundError < Error
  end

  class GitHubAPIError < Error
  end

  class RateLimitError < GitHubAPIError
  end

  class NetworkError < Error
  end

  class Configuration
    attr_accessor github_token: String?
    attr_accessor cache_enabled: bool
    attr_accessor cache_ttl: Integer
    attr_accessor default_format: String
    attr_accessor concurrency: Integer
    attr_accessor ignore_gems: Array[String]
    attr_accessor no_color: bool

    VALID_KEYS: Array[Symbol]

    def initialize: () -> void
    def apply: (Hash[Symbol, untyped] hash) -> void
  end

  class ConfigLoader
    USER_CONFIG_DIR: String
    USER_CONFIG_PATH: String
    PROJECT_CONFIG_NAME: String

    def initialize: (?project_dir: String) -> void
    def load: () -> Hash[Symbol, untyped]

    private

    def project_config_path: () -> String
    def load_file: (String path) -> Hash[Symbol, untyped]
  end

  class Cache
    DEFAULT_DIR: String
    DEFAULT_TTL: Integer

    def initialize: (?cache_dir: String, ?ttl: Integer, ?enabled: bool) -> void
    def get: (URI::Generic uri, ?headers: Hash[String, String]) -> (Net::HTTPResponse | CachedResponse)
    def clear: () -> void

    private

    def cache_key: (URI::Generic uri) -> String
    def entry_path: (String key) -> String
    def read_entry: (String key) -> Hash[String, untyped]?
    def write_entry: (String key, body: String, code: String, etag: String?) -> void
    def fresh?: (Hash[String, untyped] entry) -> bool
    def revalidate: (URI::Generic uri, Hash[String, String] headers, Hash[String, untyped] entry, String key) -> (Net::HTTPResponse | CachedResponse)
    def fetch_and_store: (URI::Generic uri, Hash[String, String] headers, String key) -> Net::HTTPResponse
    def fetch_from_network: (URI::Generic uri, Hash[String, String] headers) -> Net::HTTPResponse
    def store_response: (String key, Net::HTTPResponse response) -> void
    def build_response: (Hash[String, untyped] entry) -> CachedResponse
  end

  class CachedResponse
    attr_reader body: String
    attr_reader code: String

    def initialize: (String body, String code) -> void
    def is_a?: (Class klass) -> bool
    def []: (String _header) -> nil
  end

  class OutdatedGem
    attr_reader name: String
    attr_reader current_version: String
    attr_reader newest_version: String

    def self.new: (name: String, current_version: String, newest_version: String) -> OutdatedGem
  end

  class Detector
    PARSEABLE_REGEX: Regexp

    def initialize: (?group: String?) -> void
    def detect: () -> Array[OutdatedGem]

    private

    def run_bundle_outdated: () -> String
    def parse: (String output) -> Array[OutdatedGem]
  end

  class UriResolver
    GITHUB_REGEX: Regexp
    NON_GITHUB_HOSTS: Hash[String, String]
    URI_FIELDS: Array[String]
    MAX_REDIRECTS: Integer

    def resolve: (Hash[String, untyped] gem_data) -> String?

    private

    def extract_uris: (Hash[String, untyped] data) -> Array[String]
    def detect_non_github: (Array[String] uris) -> String?
    def extract_github_slug: (Array[String] uris) -> String?
    def follow_redirects: (String slug, ?Integer remaining) -> String
    def execute_head_request: (URI::Generic uri) -> (Net::HTTPResponse)
    def request_headers: () -> Hash[String, String]
  end

  class RubygemsClient
    RUBYGEMS_API: String

    def initialize: (?cache: Cache?, ?uri_resolver: UriResolver) -> void
    def repo_url: (String gem_name) -> String?
    def latest_version: (String gem_name) -> String?

    private

    def fetch_gem_data: (String gem_name) -> Hash[String, untyped]?
  end

  class LockfileParser
    def initialize: (?rubygems_client: RubygemsClient) -> void
    def detect: (?lockfile_path: String) -> Array[OutdatedGem]

    private

    def find_outdated: (Array[untyped] specs) -> Array[OutdatedGem]
    def check_gem: (untyped spec) -> OutdatedGem?
  end

  type release_hash = {
    tag_name: String,
    name: String?,
    published_at: String?,
    body: String?
  }

  class ChangelogParser
    CONTENTS_URL: String
    FILENAMES: Array[String]
    VERSION_HEADING: Regexp

    def initialize: (?cache: Cache?) -> void
    def entries_between: (String repo, String current_version, String newest_version) -> Array[release_hash]

    private

    def fetch_changelog: (String repo) -> String?
    def fetch_file: (String repo, String path) -> String?
    def execute_request: (URI::Generic uri) -> (Net::HTTPResponse | CachedResponse)
    def request_headers: () -> Hash[String, String]
    def parse_entries: (String content, String current_version, String newest_version) -> Array[release_hash]
    def build_entry: (String version_str, String body, Gem::Version current, Gem::Version newest) -> release_hash?
    def split_sections: (String content) -> Array[[String, String]]
    def process_line: (String line, Array[[String, String]] sections, String? current_version, Array[String] current_body) -> [String?, Array[String]]
    def flush_section: (Array[[String, String]] sections, String? version, Array[String] body) -> void
    def clean_version: (String raw) -> String
  end

  class SourceResolver
    def initialize: (?github_client: GithubClient, ?changelog_parser: ChangelogParser) -> void
    def resolve: (String repo, String current_version, String newest_version) -> Array[release_hash]
  end

  class GithubClient
    RELEASES_URL: String
    TAG_VERSION_REGEX: Regexp
    RATE_LIMIT_WARNING_THRESHOLD: Integer

    def initialize: (?cache: Cache?) -> void
    def releases_between: (String repo, String current_version, String newest_version) -> Array[release_hash]

    private

    def fetch_releases: (String repo) -> Array[Hash[String, untyped]]
    def execute_request: (URI::Generic uri) -> (Net::HTTPResponse | CachedResponse)
    def request_headers: () -> Hash[String, String]
    def handle_response: (Net::HTTPResponse | CachedResponse response) -> Array[Hash[String, untyped]]
    def check_rate_limit: (Net::HTTPResponse | CachedResponse response) -> void
    def filter_releases: (Array[Hash[String, untyped]] releases, String current_version, String newest_version) -> Array[release_hash]
    def build_release: (Hash[String, untyped] release, Gem::Version current, Gem::Version newest) -> release_hash?
    def sort_releases: (Array[release_hash] releases) -> Array[release_hash]
    def extract_version: (String? tag) -> String?
  end

  class ConcurrentFetcher
    def initialize: (?concurrency: Integer) -> void
    def fetch_all: [T, U] (Array[T], &) -> Array[U]

    private

    def spawn_workers: (Queue[untyped], Array[untyped], &) -> Array[Thread]
    def process_queue: (Queue[untyped], Array[untyped], &) -> void
  end

  type gem_report = {
    gem: OutdatedGem,
    releases: Array[release_hash],
    ?error: String
  }

  module Formatters
    def self.build: (format: String, ?color: bool) -> Base

    class Base
      def initialize: (?color: bool) -> void
      def format: (Array[gem_report] gem_reports) -> String

      private

      def summary_counts: (Array[gem_report] gem_reports) -> { total: Integer, with_changelogs: Integer, skipped: Integer }
    end

    class Text < Base
      BOLD: String
      CYAN: String
      GREEN: String
      YELLOW: String
      RED: String
      RESET: String

      def initialize: (?color: bool) -> void
      def format: (Array[gem_report] gem_reports) -> String

      private

      def default_color?: () -> bool
      def format_gem: (gem_report report) -> String
      def format_release: (release_hash release) -> String
      def summary: (Array[gem_report] gem_reports) -> String
      def colorize: (String text, *String codes) -> String
    end

    class Json < Base
      def format: (Array[gem_report] gem_reports) -> String

      private

      def format_gem: (gem_report report) -> Hash[Symbol, untyped]
      def stringify_release: (release_hash release) -> Hash[Symbol, untyped]
    end

    class Markdown < Base
      def format: (Array[gem_report] gem_reports) -> String

      private

      def format_gem: (gem_report report) -> String
      def format_release: (release_hash release) -> String
      def summary: (Array[gem_report] gem_reports) -> String
    end
  end

  Formatter: singleton(Formatters::Text)

  class Interactive
    def initialize: (gems: Array[OutdatedGem]) -> void
    def select: () -> Array[OutdatedGem]
  end

  class CLI < Thor
    def self.exit_on_failure?: () -> bool

    def check: (*String gem_names) -> void
    def show: (String gem_name, String from_version, String to_version) -> void
    def cache: (?String? subcommand) -> void
    def init: () -> void
    def version: () -> void

    private

    def load_config: () -> void
    def dry_run_output: (Array[OutdatedGem] gems) -> void
    def format_dry_run: (Array[OutdatedGem] gems) -> String
    def rails_credentials_token: () -> String?
    def output_results: (Array[OutdatedGem] gems) -> void
    def resolved_format: () -> String
    def resolved_concurrency: () -> Integer
    def build_single_report: (OutdatedGem gem) -> gem_report
    def config_template: () -> String
    def with_spinner: [T] () { () -> T } -> T
    def color_enabled?: () -> bool
    def configure_token: () -> void
    def build_cache: () -> Cache
    def detect_gems: () -> Array[OutdatedGem]
    def detect_with_fallback: () -> Array[OutdatedGem]
    def detect_via_lockfile: () -> Array[OutdatedGem]
    def filter_gems: (Array[OutdatedGem] gems, Array[String] gem_names) -> Array[OutdatedGem]
    def ignore_list: () -> Array[String]
    def build_reports: (Array[OutdatedGem] gems) -> Array[gem_report]
    def build_gem_report: (OutdatedGem gem, RubygemsClient rubygems_client, SourceResolver source_resolver) -> gem_report
    def write_output: (String text) -> void
    def log: (String message) -> void
    def log_warning: (String message) -> void
  end
end